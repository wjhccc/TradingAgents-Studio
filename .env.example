# ============================================================
# TradingAgents-Studio — environment template
# Copy this file to `.env` and fill in only the values you need.
# Everything below is OPTIONAL except the API key(s) for whichever
# LLM provider(s) you plan to use.
# ============================================================

# ---- LLM providers (set the one(s) you use) ----------------
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
DASHSCOPE_CN_API_KEY=
ZHIPU_API_KEY=
ZHIPU_CN_API_KEY=
MINIMAX_API_KEY=
MINIMAX_CN_API_KEY=
OPENROUTER_API_KEY=

# ---- Azure OpenAI (only if llm_provider=azure) -------------
# Endpoint + deployment are mandatory for Azure; key required too.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=
# OPENAI_API_VERSION=2024-10-21  # optional, required for non-v1 API

# ---- Ollama (local LLM runtime) ----------------------------
# Defaults to http://localhost:11434/v1 when unset. Point at a
# remote Ollama host if you run one separately.
#OLLAMA_BASE_URL=http://your-ollama-host:11434/v1

# ---- Market-data API keys (all optional) -------------------
# A-share: AKShare is the free default and needs no token.
# Tushare Pro is an optional paid-grade fallback — get a token
# at https://tushare.pro/ . Without this var, A-share calls go
# straight to AKShare and skip Tushare.
TUSHARE_TOKEN=

# Alpha Vantage: optional fallback for US prices / fundamentals
# / news / insider data. Free tier is 25 req/day. Without this,
# the vendor router skips Alpha Vantage and uses yfinance only.
ALPHA_VANTAGE_API_KEY=

# ---- Web Studio access password (HIGHLY recommended on a -----
# ---- public server) ----------------------------------------
# When TRADINGAGENTS_WEB_PASSWORD is set, every request needs
# HTTP Basic credentials — the browser shows a native login
# prompt (no frontend change). Leave it unset to disable auth
# (fine for localhost). User defaults to "admin".
#TRADINGAGENTS_WEB_USER=admin
#TRADINGAGENTS_WEB_PASSWORD=change-me-to-a-strong-password

# ---- Optional: DEFAULT_CONFIG overrides --------------------
# Any TRADINGAGENTS_* variable below, when set, replaces the
# matching key in tradingagents/default_config.py. Values are
# coerced to the type of the existing default (bool / int / str),
# so "true"/"3" work as expected.
#TRADINGAGENTS_LLM_PROVIDER=deepseek
#TRADINGAGENTS_DEEP_THINK_LLM=deepseek-v4-pro
#TRADINGAGENTS_QUICK_THINK_LLM=deepseek-v4-flash
#TRADINGAGENTS_LLM_BACKEND_URL=
#TRADINGAGENTS_OUTPUT_LANGUAGE=Chinese
#TRADINGAGENTS_MAX_DEBATE_ROUNDS=1
#TRADINGAGENTS_MAX_RISK_ROUNDS=1
#TRADINGAGENTS_CHECKPOINT_ENABLED=false

# ---- Concurrency tuning ------------------------------------
# Global ceiling on simultaneous LLM requests across ALL analyses
# (every analyst of every concurrently-running ticker funnels
# through one semaphore). Raise for higher provider quotas, lower
# if you hit 429s. Default 16.
#TRADINGAGENTS_LLM_CONCURRENCY=16
# Retries with exponential backoff when an LLM call is rate-limited.
#TRADINGAGENTS_LLM_MAX_RETRIES=5
# Max analysts running at once within a single analysis. 0 = no cap
# (all selected analysts in parallel); the LLM_CONCURRENCY semaphore
# above is the real throttle.
#TRADINGAGENTS_ANALYST_CONCURRENCY=0
# How many full analyses (graphs) run concurrently, and the worker
# pool that backs them. Batch/multi-ticker runs queue past these.
#TRADINGAGENTS_MAX_CONCURRENT_ANALYSES=3
#TRADINGAGENTS_HEAVY_WORKERS=4
